  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "^16.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.0",
    "eslint-config-next": "^16.1.6",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
