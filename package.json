{
  "name": "whosmetric",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
