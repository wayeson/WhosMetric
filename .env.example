# ─── Required ──────────────────────────────────────────────────────────────────
# Claude AI — all AI features (appraisals, dropped domains, news, sales, trends)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Strongly Recommended ──────────────────────────────────────────────────────
# Canonical base URL — used for OG tags, sitemap, robots.txt, and canonical links
NEXT_PUBLIC_APP_URL=https://packetally.com

# ─── Optional: Persistent Redis Cache ─────────────────────────────────────────
# Without this, caching is in-process only (resets on each Railway deployment)
# Sign up free at https://upstash.com — create a Redis database, copy REST credentials
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ─── Optional: Cache TTL ───────────────────────────────────────────────────────
# How long to cache RDAP + AI results (seconds). Default: 3600 (1 hour)
CACHE_TTL=3600

# ─── Affiliate IDs (replace AFFLID with your real IDs) ────────────────────────
# Sign up at each registrar's affiliate program, then update affiliates.txt
# Namecheap:  https://www.namecheap.com/affiliates/
# Dynadot:    https://www.dynadot.com/affiliate/
# Porkbun:    https://porkbun.com/partners
# GoDaddy:    https://www.godaddy.com/affiliate-programs
# Spaceship:  https://www.spaceship.com/affiliate/
